{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Potter: Backend Dev Server",
      "type": "shell",
      "command": "python -m uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "potter-backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Potter: Frontend Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "potter-frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "Potter: Run App",
      "dependsOn": [
        "Potter: Backend Dev Server",
        "Potter: Frontend Dev Server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
