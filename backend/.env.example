APP_ENV=development
APP_NAME=Potter Profits API
DEBUG=true
FRONTEND_ORIGIN=http://localhost:3000

# Local collector DB. This is what Potter writes to continuously on your machine.
LOCAL_DATABASE_URL=sqlite:///./potter_local.db

# Remote sync target. By default, Potter treats DATABASE_URL as the Supabase target.
DATABASE_URL=postgresql+psycopg://postgres.YOUR_PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres
REMOTE_DATABASE_URL=
ENABLE_REMOTE_SYNC=true
SYNC_INTERVAL_SECONDS=900

DEFAULT_MARKET_SOURCE=kalshi
DEFAULT_NEWS_SOURCE=newsapi
ENABLED_MARKET_SOURCES=kalshi,polymarket
MARKET_FETCH_LIMIT=100
NEWS_FETCH_LIMIT=3

POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_API_KEY=

KALSHI_API_URL=https://api.elections.kalshi.com
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_PAPER_TRADING=true
LIVE_TRADING_ENABLED=false
MAX_PAPER_TRADE_SIZE=250
MAX_LIVE_TRADE_SIZE=25
DAILY_LOSS_LIMIT=100

NEWSAPI_API_URL=https://newsapi.org/v2
NEWSAPI_API_KEY=

GNEWS_API_URL=https://gnews.io/api/v4
GNEWS_API_KEY=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

OPENAI_API_KEY=

ENABLE_SCHEDULER=false
MARKET_POLL_SECONDS=300
NEWS_POLL_SECONDS=1800
MODEL_POLL_SECONDS=600
ENABLE_HISTORICAL_BACKFILL=true
HISTORICAL_BACKFILL_DAYS=30
HISTORICAL_BACKFILL_MARKET_LIMIT=25
HISTORICAL_BACKFILL_INTERVAL_SECONDS=86400
HISTORICAL_CANDLE_INTERVAL_MINUTES=1440
ENABLE_MODEL_TRAINING=true
MODEL_TRAIN_INTERVAL_SECONDS=21600
MODEL_MIN_TRAINING_SAMPLES=50
